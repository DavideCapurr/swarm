# SwarmOS frontend npm config.
#
# Why every line is here:
#
# ignore-scripts=true
#   Defends against TanStack-style supply-chain attacks. Disables lifecycle
#   scripts (preinstall/install/postinstall/prepare) on package install so a
#   compromised transitive dep can't execute arbitrary code on `npm install`.
#   If a legitimate dep needs a script, we add it to an allowlist in CI
#   explicitly rather than re-enable scripts globally.
#
# audit=false
#   Disables the implicit audit that runs on `npm install`. The explicit
#   `npm audit --audit-level=high` step in CI is the single source of truth
#   for audit results — running it twice with different thresholds (install
#   vs. dedicated step) just produces confusing exit codes.
#
# fund=false
#   Funding banners pollute logs and can hide real warnings.
#
# engine-strict=true
#   Honor the `engines` field in package.json. A mismatching Node version
#   refuses to install instead of silently producing a broken build.
#
# loglevel=warn
#   Quieter installs; surface what matters.

ignore-scripts=true
audit=false
fund=false
engine-strict=true
loglevel=warn
