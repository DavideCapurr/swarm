{
  "name": "swarm-os-frontend",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "audit": "pnpm audit --audit-level=high",
    "test": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "maplibre-gl": "^5.24.0",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^10.4.0",
    "eslint-config-next": "^16.2.6",
    "eslint-plugin-security": "^4.0.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.0"
  },
  "pnpm": {
    "overrides": {
      "next@16.2.6>postcss": "^8.5.14",
      "next>postcss": "^8.5.14",
      "postcss@8.4.31": "8.5.14",
      "postcss": "^8.5.15"
    }
  }
}
