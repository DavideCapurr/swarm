# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
.pytest_cache/
.cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
dist/
build/

# Node
node_modules/
.next/
out/
*.tsbuildinfo
.npm
.pnpm-store/

# Env / secrets
.env
.env.local
.env.*.local
!.env.example

# Phase 6.C — operator identity store. Real password hashes + TOTP
# secrets live here; the example file is the only one committed.
infra/config/operators.yaml
infra/config/operators/*.yaml
infra/config/operators.yaml.commander-totp.txt
infra/config/redis/*.crt
infra/config/redis/*.key

# Editor
.vscode/
.idea/
*.swp
.DS_Store

# Logs
*.log
logs/

# Data
data/
*.sqlite
*.db

# Phase 6.J — Vitest coverage output
frontend/coverage/

# Phase 7.D — CV asset cache. Weights + dataset samples are downloaded
# on first use, verified via SHA256 from sim/swarm_sim/cv/manifest.json,
# and never committed. `.cache/` is already ignored above; this is
# belt-and-suspenders so a missing `.cache/` rule does not silently
# leak ~6 MB / 200 MB weight binaries into the repo.
.cache/cv/
