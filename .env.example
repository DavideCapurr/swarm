# SWARM OS — environment variables
# Copy to `.env` and fill in.

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=swarm
POSTGRES_PASSWORD=swarm
POSTGRES_DB=swarm
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://swarm:swarm@localhost:5432/swarm

# ── Redis (transport bus) ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Backend ───────────────────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8765

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8765
NEXT_PUBLIC_WS_URL=ws://localhost:8765/ws/telemetry

# ── Sim ───────────────────────────────────────────────────────────────────────
SIM_TICK_HZ=10
SIM_DRONES=3
SIM_IGNITION_AT_S=10

# ── DJI Cloud API (optional — only if dji_cloud adapter is in use) ────────────
DJI_CLOUD_APP_KEY=
DJI_CLOUD_APP_SECRET=
DJI_CLOUD_MQTT_HOST=
DJI_CLOUD_MQTT_PORT=8883
DJI_CLOUD_MQTT_USER=
DJI_CLOUD_MQTT_PASSWORD=

# ── MAVLink (optional — for real PX4/ArduPilot via SITL or hardware) ──────────
MAVLINK_CONNECTION=udp://:14540
