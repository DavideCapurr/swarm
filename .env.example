# SWARM OS — environment variables
# Copy to `.env` and fill in.

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=swarm
POSTGRES_PASSWORD=
POSTGRES_DB=swarm
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=

# ── Redis (transport bus) ─────────────────────────────────────────────────────
SWARM_ENV=dev
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=
# Set to 1 for staging/bench runs that must enforce Phase 6 secure bus entry
# criteria before SWARM_ENV=prod. Production also enforces this automatically.
SWARM_REQUIRE_SECURE_BUS=0
# Required when SWARM_ENV=prod or SWARM_REQUIRE_SECURE_BUS=1:
# REDIS_URL must be rediss:// and these three files must exist.
REDIS_TLS_CA_CERTS=
REDIS_TLS_CERTFILE=
REDIS_TLS_KEYFILE=

# ── Backend ───────────────────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8765
SWARM_ALLOWED_ORIGINS=http://localhost:3000

# ── Auth (Phase 6.C) ──────────────────────────────────────────────────────────
# HS256 signing secret (≥ 32 bytes). Generate with `openssl rand -hex 32`
# or via `make bootstrap-auth-dev` for a local dev run. Production deploys
# must mount a vault-managed secret here — never commit the real value.
SWARM_JWT_SECRET=
# Path to the operator identity store (YAML). Default is
# `infra/config/operators.yaml`. `make bootstrap-auth-dev` writes a starter
# file with three local accounts (viewer / operator / commander).
SWARM_OPERATORS_CONFIG=infra/config/operators.yaml
# Optional TTL overrides (defaults: 900 s access, 28 800 s refresh).
# SWARM_JWT_ACCESS_TTL_S=900
# SWARM_JWT_REFRESH_TTL_S=28800
# Dev-only escape hatch — the lifespan fails closed when missing config in
# `SWARM_ENV=prod`. Never set to 1 in prod.
# SWARM_AUTH_DISABLED=0

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8765
NEXT_PUBLIC_WS_URL=ws://localhost:8765/ws/telemetry

# ── Sim ───────────────────────────────────────────────────────────────────────
SIM_TICK_HZ=10
SIM_DRONES=3
SIM_IGNITION_AT_S=10
SWARM_VENDORS=simulator

# ── DJI Cloud API (optional — only if dji_cloud adapter is in use) ────────────
DJI_CLOUD_APP_KEY=
DJI_CLOUD_APP_SECRET=
DJI_CLOUD_MQTT_HOST=
DJI_CLOUD_MQTT_PORT=8883
DJI_CLOUD_MQTT_USER=
DJI_CLOUD_MQTT_PASSWORD=

# ── MAVLink (optional — for real PX4/ArduPilot via SITL or hardware) ──────────
MAVLINK_CONNECTION=udp:localhost:14540
MAVLINK_AGENT_ID=mav-001
MAVLINK_MODEL=px4-x500
MAVLINK_STREAM_URL=
MAVLINK_RATE_LIMIT_HZ=50
